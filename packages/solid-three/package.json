{
  "name": "solid-three",
  "version": "0.3.0-next.12",
  "description": "SolidJS bindings for ThreeJS",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-three.git"
  },
  "type": "module",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**",
    "types/**",
    "README.md"
  ],
  "scripts": {
    "build:dev": "vite build playground",
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "demo": "vite demo",
    "dev": "vite playground",
    "format": "prettier --write",
    "lint:circular": "dpdm -T src",
    "lint:code": "eslint --max-warnings 0 src/**/*.{ts,tsx}",
    "lint:types": "tsc --noEmit",
    "lint": "pnpm lint:circular && pnpm lint:code && pnpm lint:types",
    "prepublishOnly": "pnpm lint && pnpm build",
    "test": "vitest run",
    "types": "tsc --emitDeclarationOnly --declarationDir types"
  },
  "exports": {
    ".": {
      "solid": {
        "development": "./dist/index.dev.solid.jsx",
        "import": "./dist/index.dev.js"
      },
      "development": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.dev.js"
        }
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./testing": {
      "solid": {
        "development": "./dist/testing.dev.solid.jsx",
        "import": "./dist/testing.dev.js"
      },
      "development": {
        "import": {
          "types": "./dist/testing.d.ts",
          "default": "./dist/testing.dev.js"
        }
      },
      "import": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing.js"
      }
    }
  },
  "typesVersions": {
    "*": {
      "testing": [
        "./dist/testing/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "debounce": "^2.1.0"
  },
  "devDependencies": {
    "@solidjs/router": "0.17.0-next.1",
    "@solidjs/testing-library": "^0.8.10",
    "@solidjs/web": "2.0.0-experimental.16",
    "@types/three": "^0.164.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "dpdm": "^3.14.0",
    "esbuild": "^0.21.4",
    "babel-preset-solid": "^2.0.0-beta.5",
    "@babel/core": "^7.20.12",
    "@babel/preset-typescript": "^7.18.6",
    "esbuild-register": "^3.5.0",
    "eslint": "^9.32.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "jest": "^29.7.0",
    "jiti": "^2.5.1",
    "jsdom": "^24.1.0",
    "prettier": "^3.8.3",
    "remark-gfm": "^3.0.1",
    "rollup": "^4.18.0",
    "rollup-plugin-dts": "^6.1.1",
    "solid-app-router": "^0.1.14",
    "solid-js": "^2.0.0-beta.5",
    "three": "^0.164.1",
    "three-stdlib": "^2.36.0",
    "tsm": "^2.3.0",
    "tsup": "^8.0.2",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "^5.4.5",
    "vite": "8.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-inspect": "0.8.4",
    "vite-plugin-solid": "next",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@types/three": "*",
    "solid-js": "*",
    "three": "*"
  },
  "jest": {
    "preset": "scripts/jest/node"
  }
}
